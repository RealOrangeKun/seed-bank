sequenceDiagram
    participant U as User
    participant API as FastAPI
    participant DB as PostgreSQL

    U->>API: GET /api/stats
    API->>API: Extract device fingerprint
    API->>DB: Find User by fingerprint
    
    alt User not found
        DB-->>API: null
        API-->>U: Empty statistics
    else User found
        DB-->>API: User record
        API->>DB: SELECT COUNT(*) FROM scan_batches
        DB-->>API: total_batches
        API->>DB: SELECT SUM(total_seeds), SUM(bad_seeds_count) FROM scan_batches
        DB-->>API: Aggregated counts
        API->>DB: SELECT AVG(processing_duration_ms) FROM scan_batches
        DB-->>API: avg_processing_time
        API->>API: Calculate percentages
        API-->>U: { total_batches, total_seeds, quality_rate, ... }
    end
