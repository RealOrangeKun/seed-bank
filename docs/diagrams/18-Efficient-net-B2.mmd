graph TD
    %% Define styles
    classDef input fill:#f9f,stroke:#333,stroke-width:2px;
    classDef backbone fill:#bdf,stroke:#333,stroke-width:2px;
    classDef attention fill:#f96,stroke:#333,stroke-width:2px;
    classDef pooling fill:#ff9,stroke:#333,stroke-width:2px;
    classDef output fill:#bfb,stroke:#333,stroke-width:2px;

    %% Nodes Definition
    Input["Input Seed Crop<br/>(260 × 260 × 3)"]:::input
    
    subgraph Backbone [EfficientNet-B2 Feature Extractor]
        EffNet["Pretrained EfficientNet-B2<br/>(Final Feature Map Layer)"]:::backbone
    end

    subgraph AttentionBlock [CBAM: Convolutional Block Attention Module]
        direction TB
        Identity["Residual Identity Path"]:::attention
        
        subgraph ChannelAttention [Channel Attention Block]
            AvgPoolC["Global Avg Pooling"]:::attention
            MaxPoolC["Global Max Pooling"]:::attention
            SharedMLP["Shared 2-Layer MLP<br/>(1×1 Convolutions)"]:::attention
            SumC["Summation & Sigmoid Gate"]:::attention
            ApplyC["Multiply Channel Weights"]:::attention
            
            AvgPoolC --> SharedMLP
            MaxPoolC --> SharedMLP
            SharedMLP --> SumC
        end
        
        subgraph SpatialAttention [Spatial Attention Block]
            AvgPoolS["Channel-wise Mean Pooling"]:::attention
            MaxPoolS["Channel-wise Max Pooling"]:::attention
            ConcatS["Channel Concatenation<br/>(2-Channel Map)"]:::attention
            Conv7x7["7×7 Convolution Layer"]:::attention
            SigmoidS["Sigmoid Spatial Gate"]:::attention
            ApplyS["Multiply Spatial Weights"]:::attention
            
            AvgPoolS --> ConcatS
            MaxPoolS --> ConcatS
            ConcatS --> Conv7x7
            Conv7x7 --> SigmoidS
        end
        
        ResidualSum["Element-wise Addition<br/>(Refined Map + Identity)"]:::attention
    end

    subgraph Head [Hybrid Classification Head]
        direction TB
        GAP["Global Average Pooling<br/>(GAP: 1408 × 1 × 1)"]:::pooling
        GMP["Global Max Pooling<br/>(GMP: 1408 × 1 × 1)"]:::pooling
        ConcatHead["Vector Splicing / Concatenation<br/>(Combined Dim: 2816)"]:::pooling
        Drop["Dropout Layer<br/>(Rate: 0.25)"]:::pooling
        Dense["Linear Projection Layer<br/>(Fully Connected Layer)"]:::output
    end

    Output["Raw Defect Logits<br/>(7-Way Multi-Label Vector)"]:::output

    %% Inter-connections / Data Flow
    Input --> EffNet
    EffNet --> Identity
    EffNet --> AvgPoolC & MaxPoolC
    
    SumC --> ApplyC
    ApplyC --> AvgPoolS & MaxPoolS
    
    SigmoidS --> ApplyS
    ApplyS --> ResidualSum
    Identity --> ResidualSum
    
    ResidualSum --> GAP & GMP
    GAP --> ConcatHead
    GMP --> ConcatHead
    ConcatHead --> Drop
    Drop --> Dense
    Dense --> Output