# Database Configuration Template
# Copy this to .env and adjust as needed

DATABASE_URL=postgresql+psycopg://seedbank:seedbank_dev_password@localhost:5432/seedbank_db

# Image Storage (local for now, MinIO-ready paths)
UPLOAD_DIR=uploads
STORAGE_TYPE=local

# Application Settings
ENVIRONMENT=development

# CORS: comma-separated allowed origins. Default "*" (any origin, credentials disabled).
# For credentialed requests, list explicit origins, e.g.:
# CORS_ORIGINS=http://localhost:8080,https://app.example.com
CORS_ORIGINS=*

# Roboflow (only needed for the /api/analyze/fast and /api/analyze-batch/fast endpoints).
# Without a key, those endpoints return 503. Never commit a real key.
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=maize-gslkp-3pcv5/9

# Rate limiting + upload guards (set RATE_LIMIT_REQUESTS=0 to disable rate limiting).
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_S=60
MAX_UPLOAD_MB=10
MAX_BATCH_IMAGES=20

# Logging
LOG_LEVEL=INFO

# docker-compose host ports (override to avoid clashes with other local services)
POSTGRES_HOST_PORT=5432
API_HOST_PORT=8000
WEB_HOST_PORT=8080
ADMINER_HOST_PORT=8081

