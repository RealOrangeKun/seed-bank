# Copy to `.env` (or `.env.local`) and adjust. All frontend config is env-driven
# (no hardcoded URLs in code), mirroring the backend's Settings pillar.

# API ORIGIN only — no path. The /api/v1 prefix is baked into the generated
# OpenAPI paths, so this must be the scheme+host (+port), e.g.:
VITE_API_BASE_URL=http://localhost:8000
