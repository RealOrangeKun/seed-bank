# Copy to `.env` and fill in. `.env` is gitignored.
#
# Anything that varies between environments goes here. Code reads these via
# `seedbank.core.config.Settings` — never via `os.environ` directly.

# ── Service identity ─────────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=INFO
DEBUG=false

# ── HTTP / CORS ──────────────────────────────────────────────────────────────
# JSON list:
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
TRUSTED_HOSTS=["*"]

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
BCRYPT_ROUNDS=12
API_KEY_PREFIX=seedbank_

# OAuth — leave blank in dev unless you've registered apps.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=seedbank
POSTGRES_PASSWORD=seedbank
POSTGRES_DB=seedbank
POSTGRES_DSN=postgresql+asyncpg://seedbank:seedbank@postgres:5432/seedbank
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=5

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_DSN=redis://redis:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=seedbank
MINIO_SECRET_KEY=seedbank-dev-secret
MINIO_SECURE=false

# ── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=seedbank
CLICKHOUSE_PASSWORD=seedbank-dev-secret
CLICKHOUSE_DATABASE=seedbank

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=seedbank

# ── Inference ────────────────────────────────────────────────────────────────
INFERENCE_DEFAULT_BACKEND=torch_local
ROBOFLOW_API_KEY=

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
ENABLE_METRICS=true
