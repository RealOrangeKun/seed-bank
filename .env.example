# Copy to `.env` and fill in. `.env` is gitignored.
#
# Anything that varies between environments goes here. Code reads these via
# `seedbank.core.config.Settings` — never via `os.environ` directly.

# ── Service identity ─────────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=INFO
DEBUG=false

# ── HTTP / CORS ──────────────────────────────────────────────────────────────
# JSON list:
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
TRUSTED_HOSTS=["*"]

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
BCRYPT_ROUNDS=12
API_KEY_PREFIX=seedbank_

# OAuth — leave blank in dev unless you've registered apps.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=seedbank
POSTGRES_PASSWORD=seedbank
POSTGRES_DB=seedbank
POSTGRES_DSN=postgresql+asyncpg://seedbank:seedbank@postgres:5432/seedbank
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=5

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_DSN=redis://redis:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=seedbank
MINIO_SECRET_KEY=seedbank-dev-secret
MINIO_SECURE=false

# ── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=seedbank
CLICKHOUSE_PASSWORD=seedbank-dev-secret
CLICKHOUSE_DATABASE=seedbank

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=seedbank

# ── Inference ────────────────────────────────────────────────────────────────
INFERENCE_DEFAULT_BACKEND=torch_local
ROBOFLOW_API_KEY=

# ── Observability (Phase 9) ──────────────────────────────────────────────────
# Prometheus /metrics endpoint + HTTP middleware kill switch.
ENABLE_METRICS=true
# OTel: blank disables tracing entirely (every instrumentor is a no-op).
# Set to your OTLP gRPC collector, e.g. http://otel-collector:4317.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Sentry: blank disables the SDK entirely.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Grafana (obs profile only). GRAFANA_PASSWORD has NO default — the
# container fails to start if unset. Set it before `make up-obs`.
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ── Production (compose.prod.yaml overlay) ───────────────────────────────────
# In prod the values below are NOT set here. They live in `./secrets/*`
# files mounted via Compose `secrets:` blocks and read either through
# Pydantic Settings' `secrets_dir` (api / workers) or via the upstream
# `_FILE` convention / a small entrypoint shim (postgres, minio,
# clickhouse, mlflow, grafana). See `secrets/README.md`.
#
# Files expected under ./secrets/ (chmod 0400):
#   postgres_password, jwt_secret, minio_access_key, minio_secret_key,
#   clickhouse_password, roboflow_api_key, sentry_dsn, grafana_admin_password
#
# Verify with: `make secrets-check`
# Bring up with: `make up-prod`
#
# The non-secret prod values (POSTGRES_USER, POSTGRES_DB, CLICKHOUSE_USER,
# CLICKHOUSE_DB, GRAFANA_USER, LOG_LEVEL) ARE still read from .env in prod.
