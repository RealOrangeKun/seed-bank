# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual Environment
.venv/
venv/
ENV/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# IDE
.vscode/
.idea/
.qodo/
*.swp
*.swo
*~

# Project-specific
*.log
nohup.out

# Model weights — baked into MinIO at bootstrap, never in git.
*.pth
*.pt
*.h5
*.ckpt

# Secrets — `.env` is local; `.env.example` IS tracked.
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak

# Uploaded user data — never tracked.
uploads/

# Archived prototype — kept in git history, removed from the working tree.
# Reference only; never re-add (also excluded from build context in .dockerignore).
legacy/

# Frontend
node_modules/
compose.override.yaml

# Claude Code — the team config IS shared (committed): CLAUDE.md (root + nested
# frontend/ and mobile/), and .claude/{agents,skills,commands,hooks,memory,settings.json}.
# (.claude/memory/ is the committed TEAM memory; a developer's personal auto-memory
# lives under ~/.claude/ and is never in this repo.) Keep personal / machine-local
# bits out of git:
.claude/settings.local.json
.claude/.fuse_hidden*
.claude/launch.json
CLAUDE.local.md
