# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual Environment
.venv/
venv/
ENV/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# IDE
.vscode/
.idea/
.qodo/
*.swp
*.swo
*~

# Project-specific
*.log
nohup.out

# Model weights — baked into MinIO at bootstrap, never in git.
*.pth
*.pt
*.h5
*.ckpt

# Secrets — `.env` is local; `.env.example` IS tracked.
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak

# Uploaded user data — never tracked.
uploads/

# Archived prototype — kept in git history, removed from the working tree.
# Reference only; never re-add (also excluded from build context in .dockerignore).
legacy/

# Standalone desktop inference app + its shipped archive — source of the new
# model weights, but far too large (1.2 GB .rar, ~1.2 GB weights) to ever track.
# The weights are imported into MinIO via scripts/register_model.py, not git.
seed-bank-app/
seed-bank-app.rar

# Local model test datasets (e.g. "FASTER RCNN TESTING" / "YOLO TESTING"
# archives + their extracts) — large local ML fixtures, never tracked.
data/

# Frontend
node_modules/
compose.override.yaml

# Claude Code — the team config IS shared (committed): CLAUDE.md (root + nested
# frontend/ and mobile/), and .claude/{agents,skills,commands,hooks,memory,settings.json}.
# (.claude/memory/ is the committed TEAM memory; a developer's personal auto-memory
# lives under ~/.claude/ and is never in this repo.) Keep personal / machine-local
# bits out of git:
.claude/settings.local.json
.claude/.fuse_hidden*
.claude/launch.json
CLAUDE.local.md

# Graduation requirements documents
docs/*.pdf

# LaTeX / Pandoc compilation outputs and intermediate files
docs/report/**/*.pdf
docs/report/**/*.docx
docs/report/**/*.aux
docs/report/**/*.log
docs/report/**/*.toc
docs/report/**/*.lof
docs/report/**/*.lot
docs/report/**/*.out
docs/report/**/*.fls
docs/report/**/*.fdb_latexmk
docs/report/**/*.xdv
docs/report/**/*.bcf
docs/report/**/*.run.xml
docs/report/**/*.bbl
docs/report/**/*.blg
